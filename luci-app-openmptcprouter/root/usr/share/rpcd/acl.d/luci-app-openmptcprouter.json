{
    "luci-app-openmptcprouter": {
	"description": "Grant access to OpenMPTCProuter Wizard",
	"read": {
	    "uci": [
		"openmptcprouter",
		"network",
		"firewall",
		"shadowsocks-libev",
		"shadowsocks-rust",
		"v2ray",
		"xray",
		"glorytun",
		"dsvpn",
		"mlvpn",
		"ubond",
		"softethervpn",
		"sqm",
		"qos"
	    ],
	    "ubus": {
		"openmptcprouter": [
		    "status",
		    "wizardadd",
		    "settingsadd",
		    "updateVPS",
		    "backuplist",
		    "backupget",
		    "backupsend"
		],
		"file": [
		    "stat",
		    "exec"
		],
		"luci": [
		    "getInitList"
		],
		"network.device": [
		    "status"
		],
		"network.interface": [
		    "dump",
		    "status"
		],
		"system": [
		    "board"
		]
	    },
	    "file": {
		"/etc/init.d/shadowsocks-libev": [ "stat" ],
		"/etc/init.d/shadowsocks-rust": [ "stat" ],
		"/etc/init.d/v2ray": [ "stat" ],
		"/etc/init.d/xray": [ "stat" ],
		"/etc/init.d/openvpn": [ "stat" ],
		"/etc/init.d/openvpnbonding": [ "stat" ],
		"/etc/init.d/softethervpnclient": [ "stat" ],
		"/usr/sbin/glorytun": [ "stat" ],
		"/usr/sbin/glorytun-udp": [ "stat" ],
		"/usr/sbin/dsvpn": [ "stat" ],
		"/usr/sbin/mlvpn": [ "stat" ],
		"/usr/sbin/ubond": [ "stat" ],
		"/usr/bin/wg": [ "stat" ],
		"/usr/bin/apk": [ "stat" ],
		"/usr/bin/mmcli": [ "exec" ],
		"/bin/ubus": [ "exec" ],
		"/bin/sh": [ "exec" ],
		"/proc/cpuinfo": [ "read" ],
		"/proc/sys/net/ipv4/tcp_keepalive_time": [ "read" ],
		"/proc/sys/net/ipv4/tcp_fin_timeout": [ "read" ],
		"/proc/sys/net/ipv4/tcp_syn_retries": [ "read" ],
		"/proc/sys/net/ipv4/tcp_retries1": [ "read" ],
		"/proc/sys/net/ipv4/tcp_retries2": [ "read" ],
		"/proc/sys/net/ipv4/tcp_fastopen": [ "read" ],
		"/proc/sys/net/ipv4/ip_default_ttl": [ "read" ],
		"/proc/sys/kernel/osrelease": [ "read" ],
		"/sys/devices/system/cpu/cpufreq/policy0/scaling_min_freq": [ "read", "stat" ],
		"/sys/devices/system/cpu/cpufreq/policy0/scaling_max_freq": [ "read" ],
		"/sys/devices/system/cpu/cpufreq/policy0/scaling_governor": [ "read" ],
		"/sys/devices/system/cpu/cpufreq/policy0/scaling_available_governors": [ "read" ],
		"/usr/bin/obfs-local": [ "stat" ],
		"/usr/bin/v2ray-plugin": [ "stat" ],
		"/lib/modules": [ "stat" ],
		"/dev/ttyUSB*": [ "list" ],
		"/dev/cdc-wdm*": [ "list" ]
	    }
	},
	"write": {
	    "uci": [
		"openmptcprouter",
		"network",
		"firewall",
		"shadowsocks-libev",
		"shadowsocks-rust",
		"v2ray",
		"xray",
		"glorytun",
		"dsvpn",
		"mlvpn",
		"ubond",
		"softethervpn",
		"sqm",
		"qos"
	    ],
	    "ubus": {
		"openmptcprouter": [
		    "status",
		    "wizardadd",
		    "settingsadd",
		    "updateVPS",
		    "backuplist",
		    "backupget",
		    "backupsend"
		],
		"uci": [
		    "add",
		    "apply",
		    "confirm",
		    "delete",
		    "order",
		    "set",
		    "rename"
		]
	    }
	}
    }
}