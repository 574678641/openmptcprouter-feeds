config settings 'settings'
	option enable '0'

config server 'server'
	option ip '203.0.113.1'
	option port '443'
	option insecure '1'

config auth 'auth'
	option key 'mPyVpoQWcp/5gr404xvS19aRC03o0XS2mrb2tZJ1Ii4='

config interface 'interface'
	option tun_name 'mqvpn0'
	option log_level 'info'
	option kill_switch '0'
	option reconnect '1'
	option reconnect_interval '5'
	option route_via_server '1'
	option no_routes '0'
#	list dns '1.1.1.1'
#	list dns '8.8.8.8'

config control 'control'
	option control_port '9091'
	option control_addr '127.0.0.1'

config multipath 'multipath'
	option scheduler 'wlb'
	option auto_wan '1'
