msgstr "IPv4 und IPv6"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "IPv4 only"
msgstr "Nur IPv4"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "IPv6 only"
msgstr "Nur IPv6"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Disable AAAA IPv6 DNS"
msgstr "AAAA IPv6 DNS deaktivieren"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enable ndpi"
msgstr "ndpi aktivieren"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match destination domain names. Domain-based bypass requires OpenMPTCProuter DNS to be used by clients."
msgstr "Regeln erstellen, die Ziel-Domainnamen zuordnen. Domänenbasierter Bypass erfordert, dass Clients den DNS von OpenMPTCProuter verwenden."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enable or disable this bypass rule without deleting it."
msgstr "Diese Bypass-Regel aktivieren oder deaktivieren, ohne sie zu löschen."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enter a domain name to route through the selected interface or the server VPN."
msgstr "Geben Sie einen Domainnamen ein, der über die ausgewählte Schnittstelle oder das Server-VPN geroutet werden soll."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Optional comment to help identify the purpose of this rule."
msgstr "Optionaler Kommentar, um den Zweck dieser Regel leichter zu erkennen."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Limit the rule to IPv4 results, IPv6 results, or allow both."
msgstr "Die Regel auf IPv4-Ergebnisse, IPv6-Ergebnisse oder beide beschränken."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Restrict the matched traffic to a specific transport protocol."
msgstr "Den passenden Datenverkehr auf ein bestimmtes Transportprotokoll beschränken."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Ignore IPv6 AAAA DNS answers for this rule and only use IPv4 results."
msgstr "IPv6-AAAA-DNS-Antworten für diese Regel ignorieren und nur IPv4-Ergebnisse verwenden."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match destination IP addresses or networks directly."
msgstr "Regeln erstellen, die Ziel-IP-Adressen oder Netzwerke direkt zuordnen."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enter a destination IP address or network in CIDR notation."
msgstr "Geben Sie eine Ziel-IP-Adresse oder ein Netzwerk in CIDR-Notation ein."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match destination ports, for example to steer selected services."
msgstr "Regeln erstellen, die Zielports zuordnen, um zum Beispiel ausgewählte Dienste gezielt zu leiten."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Destination port number to match."
msgstr "Zielportnummer, die übereinstimmen soll."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Protocol to match for this destination port rule."
msgstr "Zu passendes Protokoll für diese Zielport-Regel."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match source ports generated by local applications or devices."
msgstr "Regeln erstellen, die Quellports lokaler Anwendungen oder Geräte zuordnen."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Source port number to match."
msgstr "Quellportnummer, die übereinstimmen soll."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Protocol to match for this source port rule."
msgstr "Zu passendes Protokoll für diese Quellport-Regel."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match traffic from specific client devices by MAC address."
msgstr "Regeln erstellen, die Datenverkehr bestimmter Client-Geräte per MAC-Adresse zuordnen."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Match traffic coming from this client MAC address."
msgstr "Datenverkehr zuordnen, der von dieser Client-MAC-Adresse kommt."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match traffic from a local source IP address or subnet."
msgstr "Regeln erstellen, die Datenverkehr von einer lokalen Quell-IP-Adresse oder einem Subnetz zuordnen."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enter a source LAN IP address to match."
msgstr "Geben Sie eine passende LAN-Quell-IP-Adresse ein."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match destinations announced by a specific autonomous system number."
msgstr "Regeln erstellen, die Ziele zuordnen, die von einer bestimmten autonomen Systemnummer angekündigt werden."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enter the autonomous system number to match."
msgstr "Geben Sie die autonome Systemnummer ein, die übereinstimmen soll."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match application protocols or services detected by nDPI."
msgstr "Regeln erstellen, die Anwendungsprotokolle oder Dienste zuordnen, die von nDPI erkannt werden."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Select the application protocol or service name to match."
msgstr "Wählen Sie den Namen des Anwendungsprotokolls oder Dienstes, der zugeordnet werden soll."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enable deep packet inspection for this rule when nDPI support is available."
msgstr "Deep Packet Inspection für diese Regel aktivieren, wenn nDPI-Unterstützung verfügbar ist."

