msgid "VPN on server"
msgstr "VPN sul server"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Bypass using VPN configured on server."
msgstr "Bypass tramite VPN configurata sul server."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Output interface"
msgstr "Interfaccia di uscita"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Restrict to address family"
msgstr "Limita alla famiglia di indirizzi"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "IPv4 and IPv6"
msgstr "IPv4 e IPv6"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "IPv4 only"
msgstr "Solo IPv4"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "IPv6 only"
msgstr "Solo IPv6"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Disable AAAA IPv6 DNS"
msgstr "Disabilita DNS AAAA IPv6"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enable ndpi"
msgstr "Abilita ndpi"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match destination domain names. Domain-based bypass requires OpenMPTCProuter DNS to be used by clients."
msgstr "Crea regole che corrispondono ai nomi di dominio di destinazione. Il bypass basato sui domini richiede che i client usino il DNS di OpenMPTCProuter."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enable or disable this bypass rule without deleting it."
msgstr "Abilita o disabilita questa regola di bypass senza eliminarla."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enter a domain name to route through the selected interface or the server VPN."
msgstr "Inserisci un nome di dominio da instradare tramite l'interfaccia selezionata o la VPN del server."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Optional comment to help identify the purpose of this rule."
msgstr "Commento facoltativo per aiutare a identificare lo scopo di questa regola."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Limit the rule to IPv4 results, IPv6 results, or allow both."
msgstr "Limita la regola ai risultati IPv4, ai risultati IPv6 o consenti entrambi."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Restrict the matched traffic to a specific transport protocol."
msgstr "Limita il traffico corrispondente a uno specifico protocollo di trasporto."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Ignore IPv6 AAAA DNS answers for this rule and only use IPv4 results."
msgstr "Ignora le risposte DNS AAAA IPv6 per questa regola e usa solo risultati IPv4."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match destination IP addresses or networks directly."
msgstr "Crea regole che corrispondono direttamente agli indirizzi IP o alle reti di destinazione."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enter a destination IP address or network in CIDR notation."
msgstr "Inserisci un indirizzo IP di destinazione o una rete in notazione CIDR."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match destination ports, for example to steer selected services."
msgstr "Crea regole che corrispondono alle porte di destinazione, ad esempio per instradare servizi selezionati."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Destination port number to match."
msgstr "Numero di porta di destinazione da corrispondere."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Protocol to match for this destination port rule."
msgstr "Protocollo da corrispondere per questa regola sulla porta di destinazione."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match source ports generated by local applications or devices."
msgstr "Crea regole che corrispondono alle porte sorgente generate da applicazioni o dispositivi locali."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Source port number to match."
msgstr "Numero di porta sorgente da corrispondere."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Protocol to match for this source port rule."
msgstr "Protocollo da corrispondere per questa regola sulla porta sorgente."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match traffic from specific client devices by MAC address."
msgstr "Crea regole che corrispondono al traffico di specifici dispositivi client tramite indirizzo MAC."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Match traffic coming from this client MAC address."
msgstr "Corrispondi al traffico proveniente da questo indirizzo MAC client."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match traffic from a local source IP address or subnet."
msgstr "Crea regole che corrispondono al traffico proveniente da un indirizzo IP sorgente locale o da una sottorete."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enter a source LAN IP address to match."
msgstr "Inserisci un indirizzo IP LAN sorgente da corrispondere."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match destinations announced by a specific autonomous system number."
msgstr "Crea regole che corrispondono alle destinazioni annunciate da uno specifico numero di sistema autonomo."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enter the autonomous system number to match."
msgstr "Inserisci il numero di sistema autonomo da corrispondere."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match application protocols or services detected by nDPI."
msgstr "Crea regole che corrispondono ai protocolli applicativi o ai servizi rilevati da nDPI."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Select the application protocol or service name to match."
msgstr "Seleziona il protocollo applicativo o il nome del servizio da corrispondere."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enable deep packet inspection for this rule when nDPI support is available."
msgstr "Abilita l'ispezione approfondita dei pacchetti per questa regola quando il supporto nDPI è disponibile."
