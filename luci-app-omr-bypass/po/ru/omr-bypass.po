#: luci-app-omr-bypass/htdocs/luci-static/resources/view/services/omr-bypass.js:72
#: luci-app-omr-bypass/htdocs/luci-static/resources/view/services/omr-bypass.js:98
msgid "port"
msgstr "Порт"

#: luci-app-omr-bypass/htdocs/luci-static/resources/view/services/omr-bypass.js:75
#: luci-app-omr-bypass/htdocs/luci-static/resources/view/services/omr-bypass.js:101
msgid "protocol"
msgstr "протокол"

#: luci-app-omr-bypass/htdocs/luci-static/resources/view/services/omr-bypass.js:124
msgid "source MAC-Address"
msgstr "MAC-адрес источника"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "VPN on server"
msgstr "VPN на сервере"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Bypass using VPN configured on server."
msgstr "Обход через VPN, настроенный на сервере."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Output interface"
msgstr "Выходной интерфейс"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Restrict to address family"
msgstr "Ограничить семейством адресов"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "IPv4 and IPv6"
msgstr "IPv4 и IPv6"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "IPv4 only"
msgstr "Только IPv4"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "IPv6 only"
msgstr "Только IPv6"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Disable AAAA IPv6 DNS"
msgstr "Отключить DNS AAAA IPv6"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enable ndpi"
msgstr "Включить ndpi"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match destination domain names. Domain-based bypass requires OpenMPTCProuter DNS to be used by clients."
msgstr "Создает правила, соответствующие доменным именам назначения. Обход по доменам требует, чтобы клиенты использовали DNS OpenMPTCProuter."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enable or disable this bypass rule without deleting it."
msgstr "Включить или отключить это правило обхода без его удаления."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enter a domain name to route through the selected interface or the server VPN."
msgstr "Введите доменное имя, которое нужно направить через выбранный интерфейс или VPN на сервере."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Optional comment to help identify the purpose of this rule."
msgstr "Необязательный комментарий, помогающий понять назначение этого правила."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Limit the rule to IPv4 results, IPv6 results, or allow both."
msgstr "Ограничить правило результатами IPv4, IPv6 или разрешить оба варианта."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Restrict the matched traffic to a specific transport protocol."
msgstr "Ограничить совпадающий трафик конкретным транспортным протоколом."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Ignore IPv6 AAAA DNS answers for this rule and only use IPv4 results."
msgstr "Игнорировать ответы DNS AAAA IPv6 для этого правила и использовать только результаты IPv4."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match destination IP addresses or networks directly."
msgstr "Создает правила, которые напрямую сопоставляют IP-адреса или сети назначения."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enter a destination IP address or network in CIDR notation."
msgstr "Введите IP-адрес назначения или сеть в нотации CIDR."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match destination ports, for example to steer selected services."
msgstr "Создает правила, соответствующие портам назначения, например для направления отдельных сервисов."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Destination port number to match."
msgstr "Номер порта назначения для сопоставления."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Protocol to match for this destination port rule."
msgstr "Протокол для этого правила порта назначения."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match source ports generated by local applications or devices."
msgstr "Создает правила, соответствующие исходным портам локальных приложений или устройств."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Source port number to match."
msgstr "Номер исходного порта для сопоставления."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Protocol to match for this source port rule."
msgstr "Протокол для этого правила исходного порта."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match traffic from specific client devices by MAC address."
msgstr "Создает правила, соответствующие трафику от определенных клиентских устройств по MAC-адресу."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Match traffic coming from this client MAC address."
msgstr "Сопоставлять трафик, исходящий с этого MAC-адреса клиента."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match traffic from a local source IP address or subnet."
msgstr "Создает правила, соответствующие трафику от локального IP-адреса источника или подсети."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enter a source LAN IP address to match."
msgstr "Введите LAN IP-адрес источника для сопоставления."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match destinations announced by a specific autonomous system number."
msgstr "Создает правила, соответствующие назначениям, объявляемым определенной автономной системой."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enter the autonomous system number to match."
msgstr "Введите номер автономной системы для сопоставления."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match application protocols or services detected by nDPI."
msgstr "Создает правила, соответствующие протоколам приложений или сервисам, обнаруженным nDPI."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Select the application protocol or service name to match."
msgstr "Выберите протокол приложения или имя сервиса для сопоставления."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enable deep packet inspection for this rule when nDPI support is available."
msgstr "Включить глубокую инспекцию пакетов для этого правила, если доступна поддержка nDPI."
