msgstr "Contournement via le VPN configuré sur le serveur."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Output interface"
msgstr "Interface de sortie"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Restrict to address family"
msgstr "Restreindre à la famille d'adresses"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "IPv4 and IPv6"
msgstr "IPv4 et IPv6"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "IPv4 only"
msgstr "IPv4 uniquement"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "IPv6 only"
msgstr "IPv6 uniquement"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Disable AAAA IPv6 DNS"
msgstr "Désactiver les DNS AAAA IPv6"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enable ndpi"
msgstr "Activer ndpi"

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match destination domain names. Domain-based bypass requires OpenMPTCProuter DNS to be used by clients."
msgstr "Creer des regles qui correspondent aux noms de domaine de destination. Le contournement par domaine exige que les clients utilisent le DNS d'OpenMPTCProuter."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enable or disable this bypass rule without deleting it."
msgstr "Activer ou desactiver cette regle de contournement sans la supprimer."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enter a domain name to route through the selected interface or the server VPN."
msgstr "Saisir un nom de domaine a router via l'interface selectionnee ou le VPN du serveur."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Optional comment to help identify the purpose of this rule."
msgstr "Commentaire facultatif pour aider a identifier l'objectif de cette regle."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Limit the rule to IPv4 results, IPv6 results, or allow both."
msgstr "Limiter la regle aux resultats IPv4, aux resultats IPv6, ou autoriser les deux."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Restrict the matched traffic to a specific transport protocol."
msgstr "Limiter le trafic correspondant a un protocole de transport specifique."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Ignore IPv6 AAAA DNS answers for this rule and only use IPv4 results."
msgstr "Ignorer les reponses DNS AAAA IPv6 pour cette regle et n'utiliser que les resultats IPv4."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match destination IP addresses or networks directly."
msgstr "Creer des regles qui correspondent directement aux adresses IP ou aux reseaux de destination."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enter a destination IP address or network in CIDR notation."
msgstr "Saisir une adresse IP de destination ou un reseau en notation CIDR."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match destination ports, for example to steer selected services."
msgstr "Creer des regles qui correspondent aux ports de destination, par exemple pour orienter certains services."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Destination port number to match."
msgstr "Numero de port de destination a faire correspondre."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Protocol to match for this destination port rule."
msgstr "Protocole a faire correspondre pour cette regle de port de destination."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match source ports generated by local applications or devices."
msgstr "Creer des regles qui correspondent aux ports source generes par des applications ou appareils locaux."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Source port number to match."
msgstr "Numero de port source a faire correspondre."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Protocol to match for this source port rule."
msgstr "Protocole a faire correspondre pour cette regle de port source."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match traffic from specific client devices by MAC address."
msgstr "Creer des regles qui correspondent au trafic de certains appareils clients par adresse MAC."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Match traffic coming from this client MAC address."
msgstr "Faire correspondre le trafic provenant de cette adresse MAC cliente."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match traffic from a local source IP address or subnet."
msgstr "Creer des regles qui correspondent au trafic provenant d'une adresse IP source locale ou d'un sous-reseau."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enter a source LAN IP address to match."
msgstr "Saisir une adresse IP LAN source a faire correspondre."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match destinations announced by a specific autonomous system number."
msgstr "Creer des regles qui correspondent aux destinations annoncees par un numero d'autonomous system specifique."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enter the autonomous system number to match."
msgstr "Saisir le numero d'autonomous system a faire correspondre."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Create rules that match application protocols or services detected by nDPI."
msgstr "Creer des regles qui correspondent aux protocoles applicatifs ou aux services detectes par nDPI."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Select the application protocol or service name to match."
msgstr "Selectionner le nom du protocole applicatif ou du service a faire correspondre."

#: htdocs/luci-static/resources/view/services/omr-bypass.js
msgid "Enable deep packet inspection for this rule when nDPI support is available."
msgstr "Activer l'inspection approfondie des paquets pour cette regle lorsque la prise en charge de nDPI est disponible."

