#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "MQVPN"
msgstr "MQVPN"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "QUIC-based VPN tunnel"
msgstr "QUIC-basierter VPN-Tunnel"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "General"
msgstr "Allgemein"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Enabled"
msgstr "Aktiviert"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Server"
msgstr "Server"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Server IP"
msgstr "Server-IP"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "IPv4 or IPv6 address of the MQVPN server"
msgstr "IPv4- oder IPv6-Adresse des MQVPN-Servers"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Server port"
msgstr "Server-Port"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Insecure TLS"
msgstr "Unsicheres TLS"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Skip TLS certificate verification"
msgstr "TLS-Zertifikatsprüfung überspringen"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Authentication"
msgstr "Authentifizierung"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "User"
msgstr "Benutzer"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Key"
msgstr "Schlüssel"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Interface"
msgstr "Schnittstelle"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Tunnel name"
msgstr "Tunnelname"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Log level"
msgstr "Protokollierungsstufe"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Debug"
msgstr "Debug"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Info"
msgstr "Info"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Warning"
msgstr "Warnung"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Error"
msgstr "Fehler"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Kill switch"
msgstr "Kill-Switch"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Block all traffic if the VPN tunnel goes down"
msgstr "Gesamten Datenverkehr blockieren, wenn der VPN-Tunnel ausfällt"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Reconnect"
msgstr "Wiederverbindung"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Automatically reconnect on failure"
msgstr "Bei Fehler automatisch neu verbinden"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Reconnect interval"
msgstr "Wiederverbindungsintervall"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Seconds between reconnection attempts"
msgstr "Sekunden zwischen Wiederverbindungsversuchen"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Route via server"
msgstr "Route über Server"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Add a host route to the server IP before setting the default route"
msgstr "Eine Host-Route zur Server-IP hinzufügen, bevor die Standardroute gesetzt wird"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "No automatic routes"
msgstr "Keine automatischen Routen"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Skip all automatic route setup and manage routes manually"
msgstr "Automatische Routenkonfiguration überspringen und Routen manuell verwalten"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "DNS servers"
msgstr "DNS-Server"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Control API"
msgstr "Steuer-API"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Port"
msgstr "Port"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "TCP port for the JSON control API (leave empty to disable)"
msgstr "TCP-Port für die JSON-Steuer-API (leer lassen zum Deaktivieren)"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Bind address"
msgstr "Bind-Adresse"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Address to bind the control API (default: 127.0.0.1)"
msgstr "Adresse, an die die Steuer-API gebunden wird (Standard: 127.0.0.1)"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Multipath"
msgstr "Mehrfachpfad"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Scheduler"
msgstr "Scheduler"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Weighted Load Balancing"
msgstr "Gewichteter Lastausgleich"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Minimum RTT"
msgstr "Minimale RTT"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Auto WAN"
msgstr "Automatisches WAN"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Automatically add WAN interfaces as multipath paths. If disabled, use the paths defined below."
msgstr "WAN-Schnittstellen automatisch als Mehrfachpfade hinzufügen. Falls deaktiviert, werden die unten definierten Pfade verwendet."

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Paths"
msgstr "Pfade"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Network interfaces to use as multipath paths"
msgstr "Netzwerkschnittstellen, die als Mehrfachpfade verwendet werden sollen"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Backup paths"
msgstr "Backup-Pfade"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Network interfaces to use as backup multipath paths"
msgstr "Netzwerkschnittstellen, die als Backup-Mehrfachpfade verwendet werden sollen"
