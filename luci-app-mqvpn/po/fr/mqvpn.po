msgid "Route via server"
msgstr "Router via le serveur"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Add a host route to the server IP before setting the default route"
msgstr "Ajouter une route hôte vers l'IP du serveur avant de définir la route par défaut"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "No automatic routes"
msgstr "Pas de routes automatiques"

#: htdocs/luci-static/resources/view/services/mqvpn.js
