msgstr "API de contrôle"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Port"
msgstr "Port"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "TCP port for the JSON control API (leave empty to disable)"
msgstr "Port TCP pour l'API de contrôle JSON (laisser vide pour désactiver)"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Bind address"
msgstr "Adresse d'écoute"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Address to bind the control API (default: 127.0.0.1)"
msgstr "Adresse d'écoute de l'API de contrôle (défaut : 127.0.0.1)"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Multipath"
msgstr "Multichemin"

