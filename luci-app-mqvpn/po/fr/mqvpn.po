msgstr "Équilibrage de charge pondéré"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Minimum RTT"
msgstr "RTT minimum"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Auto WAN"
msgstr "WAN automatique"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Automatically add WAN interfaces as multipath paths. If disabled, use the paths defined below."
msgstr "Ajouter automatiquement les interfaces WAN comme chemins multipath. Si désactivé, utiliser les chemins définis ci-dessous."

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Paths"
msgstr "Chemins"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Network interfaces to use as multipath paths"
msgstr "Interfaces réseau à utiliser comme chemins multipath"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Backup paths"
msgstr "Chemins de secours"

#: htdocs/luci-static/resources/view/services/mqvpn.js
