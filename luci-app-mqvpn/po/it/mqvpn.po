msgstr "Bilanciamento del carico ponderato"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Minimum RTT"
msgstr "RTT minimo"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Auto WAN"
msgstr "WAN automatico"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Automatically add WAN interfaces as multipath paths. If disabled, use the paths defined below."
msgstr "Aggiunge automaticamente le interfacce WAN come percorsi multipath. Se disabilitato, utilizza i percorsi definiti di seguito."

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Paths"
msgstr "Percorsi"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Network interfaces to use as multipath paths"
msgstr "Interfacce di rete da utilizzare come percorsi multipath"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Backup paths"
msgstr "Percorsi di backup"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Network interfaces to use as backup multipath paths"
msgstr "Interfacce di rete da utilizzare come percorsi multipath di backup"
