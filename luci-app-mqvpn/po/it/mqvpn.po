msgstr "Salta la configurazione automatica delle route e gestiscile manualmente"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "DNS servers"
msgstr "Server DNS"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Control API"
msgstr "API di controllo"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Port"
msgstr "Porta"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "TCP port for the JSON control API (leave empty to disable)"
msgstr "Porta TCP per l'API di controllo JSON (lasciare vuoto per disabilitare)"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Bind address"
msgstr "Indirizzo di ascolto"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Address to bind the control API (default: 127.0.0.1)"
msgstr "Indirizzo su cui collegare l'API di controllo (predefinito: 127.0.0.1)"

#: htdocs/luci-static/resources/view/services/mqvpn.js
msgid "Multipath"
msgstr "Multipath"

