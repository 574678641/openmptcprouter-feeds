#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
#: root/usr/share/luci/menu.d/luci-app-omr-metrics.json
msgid "WAN Metrics"
msgstr "WAN-Metriken"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Live per-interface metrics collected by omr-tracker. Refreshes every %d seconds."
msgstr "Live-Metriken pro Schnittstelle, gesammelt von omr-tracker. Aktualisierung alle %d Sekunden."

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "No metrics available yet. Waiting for omr-tracker to run…"
msgstr "Noch keine Metriken verfügbar. Warten auf die Ausführung von omr-tracker…"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Up"
msgstr "Aktiv"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Down"
msgstr "Inaktiv"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Connectivity"
msgstr "Konnektivität"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Quality"
msgstr "Qualität"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Signal"
msgstr "Signal"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Traffic Control"
msgstr "Datenverkehrssteuerung"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "BBR"
msgstr "BBR"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Updated: "
msgstr "Aktualisiert: "

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Interface"
msgstr "Schnittstelle"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Logical UCI interface name"
msgstr "Logischer UCI-Schnittstellenname"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Device"
msgstr "Gerät"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Physical network device (e.g. eth0, ppp0)"
msgstr "Physisches Netzwerkgerät (z.B. eth0, ppp0)"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Status"
msgstr "Status"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Link state as detected by omr-tracker"
msgstr "Verbindungsstatus laut omr-tracker"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Message"
msgstr "Meldung"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Status detail from the last probe check"
msgstr "Statusdetail der letzten Prüfung"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "IPv4"
msgstr "IPv4"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "IPv4 address assigned to this interface"
msgstr "Der Schnittstelle zugewiesene IPv4-Adresse"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "IPv6"
msgstr "IPv6"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "IPv6 address assigned to this interface"
msgstr "Der Schnittstelle zugewiesene IPv6-Adresse"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Gateway"
msgstr "Gateway"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "IPv4 default gateway for this interface"
msgstr "Standard-IPv4-Gateway für diese Schnittstelle"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Gateway6"
msgstr "Gateway IPv6"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "IPv6 default gateway for this interface"
msgstr "Standard-IPv6-Gateway für diese Schnittstelle"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Latency"
msgstr "Latenz"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Average round-trip time to the probe target in the last measurement"
msgstr "Durchschnittliche Roundtrip-Zeit zum Prüfziel bei der letzten Messung"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "RTT min"
msgstr "RTT min"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Lowest round-trip time ever seen — baseline for bufferbloat detection"
msgstr "Niedrigste je gemessene Roundtrip-Zeit — Basis für die Bufferbloat-Erkennung"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "RTT max"
msgstr "RTT max"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Highest round-trip time seen in the last measurement"
msgstr "Höchste Roundtrip-Zeit bei der letzten Messung"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Jitter"
msgstr "Jitter"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Variation in round-trip time — high values indicate an unstable link"
msgstr "Schwankung der Roundtrip-Zeit — hohe Werte deuten auf eine instabile Verbindung hin"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Loss"
msgstr "Verlust"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Percentage of probe packets lost in the last measurement"
msgstr "Prozentsatz verlorener Prüfpakete bei der letzten Messung"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Congestion"
msgstr "Überlastung"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Composite score (0–100) computed from latency, loss, jitter, queue depth and signal quality"
msgstr "Zusammengesetzter Wert (0–100) aus Latenz, Verlust, Jitter, Warteschlangentiefe und Signalqualität"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "None"
msgstr "Keine"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Low"
msgstr "Gering"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Moderate"
msgstr "Mäßig"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "High"
msgstr "Hoch"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Severe"
msgstr "Schwerwiegend"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Type"
msgstr "Typ"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Signal source type (WiFi or cellular)"
msgstr "Signalquellentyp (WLAN oder Mobilfunk)"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "SSID"
msgstr "SSID"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Wi-Fi network name"
msgstr "WLAN-Netzwerkname"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "BSSID"
msgstr "BSSID"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Access point MAC address"
msgstr "MAC-Adresse des Zugangspunkts"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Channel"
msgstr "Kanal"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Wi-Fi channel in use"
msgstr "Genutzter WLAN-Kanal"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Mode"
msgstr "Modus"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Wi-Fi operating mode (e.g. Master, Client)"
msgstr "WLAN-Betriebsmodus (z.B. Master, Client)"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Received signal strength in dBm — less negative is better"
msgstr "Empfangssignalstärke in dBm — weniger negativ ist besser"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Noise"
msgstr "Rauschen"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Background noise floor in dBm"
msgstr "Hintergrundrauschlevel in dBm"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Bit rate"
msgstr "Bitrate"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Current negotiated radio transmission rate"
msgstr "Aktuell ausgehandelte Funkübertragungsrate"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Link quality as a percentage of the maximum"
msgstr "Verbindungsqualität als Prozentsatz des Maximums"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Operator"
msgstr "Betreiber"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Mobile network operator name"
msgstr "Name des Mobilfunkanbieters"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "State"
msgstr "Netzstatus"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Connection state reported by the modem"
msgstr "Vom Modem gemeldeter Verbindungsstatus"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Signal quality percentage reported by the modem"
msgstr "Vom Modem gemeldete Signalqualität in Prozent"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "RSSI"
msgstr "RSSI"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Received Signal Strength Indicator (dBm) — less negative is better"
msgstr "Empfangssignalstärkeindikator (dBm) — weniger negativ ist besser"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "RSRP"
msgstr "RSRP"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Reference Signal Received Power (dBm, LTE) — less negative is better"
msgstr "Referenzsignal-Empfangsleistung (dBm, LTE) — weniger negativ ist besser"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "RSRQ"
msgstr "RSRQ"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Reference Signal Received Quality (dB, LTE) — less negative is better"
msgstr "Empfangsqualität des Referenzsignals (dB, LTE) — weniger negativ ist besser"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "SINR"
msgstr "SINR"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Signal to Interference and Noise Ratio (dB) — higher is better"
msgstr "Signal-zu-Interferenz-und-Rausch-Verhältnis (dB) — höher ist besser"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Qdisc"
msgstr "Qdisc"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Active queuing discipline (e.g. fq, cake, fq_codel)"
msgstr "Aktive Warteschlangendisziplin (z.B. fq, cake, fq_codel)"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Sent"
msgstr "Gesendet"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Total bytes and packets sent since the qdisc was created"
msgstr "Insgesamt gesendete Bytes und Pakete seit der Erstellung der Qdisc"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Dropped"
msgstr "Verworfen"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Packets discarded by the qdisc — high values indicate congestion"
msgstr "Von der Qdisc verworfene Pakete — hohe Werte deuten auf Überlastung hin"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Overlimits"
msgstr "Überschreitungen"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Times the interface rate limit was exceeded"
msgstr "Wie oft das Schnittstellenratenlimit überschritten wurde"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Backlog"
msgstr "Rückstau"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Bytes and packets currently waiting in the queue to be sent"
msgstr "Bytes und Pakete, die derzeit in der Warteschlange auf den Versand warten"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "ECN mark"
msgstr "ECN-Markierung"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Packets marked for Explicit Congestion Notification instead of being dropped"
msgstr "Pakete, die statt verworfen zu werden für Explicit Congestion Notification markiert wurden"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Drop overlimit"
msgstr "Limit-Drop"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Packets dropped because the queue length limit was exceeded"
msgstr "Pakete, die aufgrund der überschrittenen Warteschlangenlänge verworfen wurden"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Flows"
msgstr "Flows"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Number of active fair-queue flows"
msgstr "Anzahl aktiver Fair-Queue-Flows"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Throttled"
msgstr "Gedrosselt"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Flows currently paused by the scheduler"
msgstr "Aktuell vom Scheduler gedrosselte Flows"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Flows plimit"
msgstr "Flows-Plimit"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Flows dropped because the per-flow packet limit was reached"
msgstr "Flows, die aufgrund des erreichten Paketlimits pro Flow verworfen wurden"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "New flows"
msgstr "Neue Flows"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "New flows opened since the last measurement"
msgstr "Seit der letzten Messung geöffnete neue Flows"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Bandwidth"
msgstr "Bandbreite"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "BBR's estimated bottleneck bandwidth (filtered maximum delivery rate from active TCP connections)"
msgstr "BBR-geschätzte Engpassbandbreite (gefilterter maximaler Lieferdurchsatz aktiver TCP-Verbindungen)"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Pacing rate"
msgstr "Schrittrate"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Rate at which BBR paces packets — set to bandwidth × pacing gain during probing"
msgstr "Rate, mit der BBR Pakete taktiert — während des Probings auf Bandbreite × Pacing-Gewinn gesetzt"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Delivery rate"
msgstr "Lieferrate"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Actual measured data delivery rate to the receiver across active TCP connections"
msgstr "Tatsächlich gemessene Datenlieferrate zum Empfänger über aktive TCP-Verbindungen"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Cwnd"
msgstr "Cwnd"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Average TCP congestion window in segments across active connections"
msgstr "Durchschnittliches TCP-Überlastfenster in Segmenten über aktive Verbindungen"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Min RTT"
msgstr "Min RTT"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Minimum round-trip time observed by BBR — used as the propagation delay baseline"
msgstr "Minimale vom BBR beobachtete Roundtrip-Zeit — als Ausbreitungsverzögerungsbasis verwendet"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Retrans"
msgstr "Neuübertragungen"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "Total retransmissions across active TCP connections — any non-zero value indicates packet loss"
msgstr "Gesamtanzahl der Neuübertragungen über aktive TCP-Verbindungen — jeder Wert > 0 zeigt Paketverlust an"

#: htdocs/luci-static/resources/view/omr-metrics/metrics.js
msgid "segs"
msgstr "Seg."

#: root/usr/share/rpcd/acl.d/luci-app-omr-metrics.json
msgid "Grant access to OpenMPTCProuter WAN Metrics"
msgstr "Zugriff auf OpenMPTCProuter WAN-Metriken gewähren"
