#: luci-app-omr-tracker/luasrc/model/cbi/omr-tracker.lua:69
#: luci-app-omr-tracker/luasrc/model/cbi/omr-tracker.lua:99
#: luci-app-omr-tracker/luasrc/model/cbi/omr-tracker.lua:174
msgid "Tries"
msgstr "尝试"

